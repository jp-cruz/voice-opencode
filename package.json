{
  "name": "voice-opencode",
  "version": "0.1.0",
  "description": "Cross-platform voice interaction layer for OpenCode AI coding agent",
  "type": "module",
  "private": true,
  "main": "src/cli/index.ts",
  "scripts": {
    "coverage": "c8 report -r text -r html",
    "precommit": "npm run lint && npm run typecheck",

    "typecheck": "tsc --noEmit",
    "release": "npm version patch && git push && git push --tags && bun run build && npm publish",
    "start": "bun run src/cli/index.ts",
    "dev": "bun --watch run src/cli/index.ts",
    "test": "bun test",
    "test:stt": "bun run scripts/test-stt.ts",
    "test:tts": "bun run scripts/test-tts.ts",
    "lint": "bun run eslint src --ext=.ts,.js",
    "build": "bun build src/cli/index.ts --outdir=dist --target=bun"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "eventsource": "^2.0.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^30.0.0",
    "c8": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
