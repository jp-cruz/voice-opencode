# Voice OpenCode Configuration

# OpenCode Server
OPENCODE_URL=http://localhost:4096

# Speech-to-Text (STT) Configuration
# Engines: whisper (local), whisper-api (cloud), google
STT_ENGINE=whisper
STT_MODEL=base
STT_LANGUAGE=en

# Text-to-Speech (TTS) Configuration
# Engines: edge, elevenlabs, coqui
TTS_ENGINE=edge
TTS_VOICE=en-US-AriaNeural
TTS_RATE=1.0
TTS_VOLUME=1.0

# Audio Configuration
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default

# API Keys (if using cloud services)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
